{
  "manifest_version": 3,
  "name": "Image Auto Downloader",
  "version": "1.1",
  "description": "Auto search and download images matching a keyword on multiple engines.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.bing.com/*",
    "*://*.yandex.com/*",
    "*://*.yandex.ru/*",
    "*://*.baidu.com/*"
  ]
}
